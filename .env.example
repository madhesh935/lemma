# ============================================================
# AEGIS-OS Environment Configuration
# Copy this file to .env and fill in the values
# ============================================================

# ─── Application ───────────────────────────────────────────
APP_NAME=AEGIS-OS
APP_VERSION=3.0.0
DEBUG=false

# ─── Security (REQUIRED: change in production!) ────────────
SECRET_KEY=your-super-secret-key-at-least-32-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── PostgreSQL ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aegis:aegis_secret@localhost:5432/aegis_db
# For Docker Compose:
# DATABASE_URL=postgresql+asyncpg://aegis:aegis_secret@postgres:5432/aegis_db

# ─── Neo4j (Knowledge Graph) ──────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=aegis_neo4j
# For Docker Compose:
# NEO4J_URI=bolt://neo4j:7687

# ─── ChromaDB (Vector Store) ──────────────────────────────
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMA_COLLECTION=aegis_evidence

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── File Storage ─────────────────────────────────────────
UPLOAD_BASE_DIR=./pod_files
MAX_UPLOAD_SIZE_MB=500

# ─── AI / LLM (Optional — for hypothesis/report generation) 
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Lemma SDK ────────────────────────────────────────────
LEMMA_WORKFLOW_CONCURRENCY=4
LEMMA_AGENT_TIMEOUT_SECONDS=120

# ─── OCR (Tesseract) ──────────────────────────────────────
# TESSERACT_CMD=/usr/bin/tesseract
# On Windows: TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ─── Frontend (Vite/TanStack) ─────────────────────────────
VITE_API_BASE=http://localhost:8000
